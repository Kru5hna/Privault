# Privault Backend — Environment Variables
# Copy this to .env and fill in your values.
# This file is read by cargo run in the backend/ directory.

PORT=8080

# PostgreSQL connection string (Supabase, Neon, or local)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Comma-separated list of allowed CORS origins
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# S3-compatible object storage (required)
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=bucket_name
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional: S3-compatible endpoint override (for R2, MinIO, Backblaze)
# AWS_ENDPOINT_URL=https://your-custom-endpoint.com

# Per-user storage quota in bytes (default: 100 MB)
STORAGE_QUOTA_BYTES=104857600

# Max single-upload body size in bytes (default: 100 MB)
MAX_UPLOAD_BYTES=104857600

# Rate limits — per-route caps inside a sliding window.
# Format: <ROUTE>_MAX requests per <ROUTE>_WINDOW_SECS seconds.
# Defaults shown — override only what you need.
# RATELIMIT_UPLOAD_MAX=10
# RATELIMIT_UPLOAD_WINDOW_SECS=60
# RATELIMIT_FOLDER_UPLOAD_MAX=5
# RATELIMIT_FOLDER_UPLOAD_WINDOW_SECS=60
# RATELIMIT_DOWNLOAD_MAX=60
# RATELIMIT_DOWNLOAD_WINDOW_SECS=60
# RATELIMIT_LOGIN_MAX=5
# RATELIMIT_LOGIN_WINDOW_SECS=60

# Email (AWS SES v2)

FROM_EMAIL=mail@localprivault.com

